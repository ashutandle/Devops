pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/<your-username>/devops-toolkit.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t myapp ./docker'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d --name mycontainer myapp'
            }
        }
    }
}
